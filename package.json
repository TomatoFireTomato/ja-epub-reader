{
  "name": "ja-epub-reader",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "日语 EPUB 小说阅读器，点击句子即可用 Claude 解析语法与单词",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:all": "concurrently -k -n web,api -c blue,green \"vite\" \"node server/index.js\""
  },
  "dependencies": {
    "@sglkc/kuromoji": "^1.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.0",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=18"
  },
  "volta": {
    "node": "22.23.1"
  }
}
